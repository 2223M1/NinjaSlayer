{
  "NINJA_SLAYER_EVENT_NANCY_LEE.title": "南希·李",
  "NINJA_SLAYER_EVENT_NANCY_LEE.epithet": "老战友",
  "NINJA_SLAYER_EVENT_NANCY_LEE.talk.firstVisitEver.0-0.ancient": "你迟到了三分四十秒，藤木户=SAN。",
  "NINJA_SLAYER_EVENT_NANCY_LEE.talk.firstVisitEver.0-0.next": "回答",
  "NINJA_SLAYER_EVENT_NANCY_LEE.talk.firstVisitEver.0-1.char": "路上有忍者。",
  "NINJA_SLAYER_EVENT_NANCY_LEE.talk.firstVisitEver.0-1.next": "继续",
  "NINJA_SLAYER_EVENT_NANCY_LEE.talk.firstVisitEver.0-2.ancient": "我猜也是。上层路线和敌人配置都在这里。你负责物理，我负责网络——和平常一样。",
  "NINJA_SLAYER_EVENT_NANCY_LEE.talk.ANY.0-0r.ancient": "西侧防火墙还能撑九十秒。你有六十秒。",
  "NINJA_SLAYER_EVENT_NANCY_LEE.talk.ANY.0-0r.next": "回答",
  "NINJA_SLAYER_EVENT_NANCY_LEE.talk.ANY.0-1r.char": "余下三十秒呢。",
  "NINJA_SLAYER_EVENT_NANCY_LEE.talk.ANY.0-1r.next": "继续",
  "NINJA_SLAYER_EVENT_NANCY_LEE.talk.ANY.0-2r.ancient": "那是我的工作。别让我白留。",
  "NINJA_SLAYER_EVENT_NANCY_LEE.talk.ANY.1-0r.ancient": "左侧有三十七个生命反应。右侧只有一个。",
  "NINJA_SLAYER_EVENT_NANCY_LEE.talk.ANY.1-0r.next": "回答",
  "NINJA_SLAYER_EVENT_NANCY_LEE.talk.ANY.1-1r.char": "右侧的是忍者。",
  "NINJA_SLAYER_EVENT_NANCY_LEE.talk.ANY.1-1r.next": "继续",
  "NINJA_SLAYER_EVENT_NANCY_LEE.talk.ANY.1-2r.ancient": "我知道。所以装备已经放在你手边了。通讯保持开放。",
  "NINJA_SLAYER_EVENT_NANCY_LEE.pages.DONE.description": "南希合上终端，确认了通往上层的路线。\n\n[sine]通讯保持开放。继续前进。[/sine]",
  "NEOW.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-0.ancient": "[sine]...两道...声音... 一具...身体.... 你是...何物...？[/sine]",
  "NEOW.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-0.next": "问候",
  "NEOW.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-1.char": "DOMO，涅奥=SAN。忍者杀手DESU。汝是忍者吗。",
  "NEOW.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-1.next": "继续",
  "NEOW.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-2.ancient": "[sine]...不是.... 向上.... 汝会...找到...应杀之人....[/sine]",
  "NEOW.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.1-0r.ancient": "[sine]...复仇者... 又一次.... 醒来... 向上去吧....[/sine]",
  "NEOW.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-0.ancient": "[sine]...你...抵达过.... 却又...回到...这里....[/sine]",
  "NEOW.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-0.next": "回答",
  "NEOW.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-1.char": "敌人未死。那便再上去。",
  "NEOW.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-1.next": "接受赐福",
  "NEOW.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-2.ancient": "[sine]...那么.... 再杀...一次....[/sine]",
  "DARV.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-0.char": "DOMO，达弗=SAN。忍者杀手DESU。",
  "DARV.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-0.next": "问候",
  "DARV.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-1.ancient": "名字怪吓人的，礼貌倒是真不错！赤黑色的家伙，我这堆里肯定有适合你的！",
  "DARV.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-1.next": "挑选",
  "DARV.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-2.char": "若能投掷，或能承受空手道，便足够。",
  "DARV.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.1-0r.ancient": "又把装备磨坏啦？拿一个拿一个——不过别朝我扔啊！",
  "DARV.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-0.ancient": "怪事！我的收藏里多了几枚用坏的手里剑。该不会是你以前落下的吧？",
  "DARV.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-0.next": "否认",
  "DARV.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-1.char": "不是。刃口的损伤，并非我的投法造成。",
  "DARV.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-1.next": "挑选",
  "DARV.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-2.ancient": "连这个都看得出来？好吧，那还是从新东西里挑一个！",
  "NONUPEIPE.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-0.ancient": "赤黑的刺客，你的杀意尚可，衣着却实在乏味。过来，让我替你添些光彩。",
  "NONUPEIPE.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-0.next": "回答",
  "NONUPEIPE.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-1.char": "装饰无用。不会妨碍空手道的赐福，可以收下。",
  "NONUPEIPE.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-1.next": "接受赐福",
  "NONUPEIPE.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-2.ancient": "真是不解风情。好吧——至少让你杀戮时显得体面些。",
  "NONUPEIPE.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.1-0r.ancient": "又是这身赤黑色？来吧，我顽固而能干的勇士。",
  "NONUPEIPE.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-0.ancient": "死去又归来这么多次，你居然一次也没有换过衣服。",
  "NONUPEIPE.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-0.next": "回答",
  "NONUPEIPE.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-1.char": "死亡改变不了使命。装束亦无须改变。",
  "NONUPEIPE.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-1.next": "接受赐福",
  "NONUPEIPE.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-2.ancient": "悲壮，却毫无品位。至少再收下一件我的赐福吧。",
  "OROBAS.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-0.ancient": "赤黑！杀气！身体里还有一个！？为什么两个？为什么都那么生气？！",
  "OROBAS.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-0.next": "回答",
  "OROBAS.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-1.char": "先回答。汝是忍者吗。",
  "OROBAS.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-1.next": "收下",
  "OROBAS.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-2.ancient": "不是！忍者很危险？你只杀忍者？很好！！拿个亮闪闪的冷静一下！",
  "OROBAS.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.1-0r.ancient": "又来？！没有少胳膊！很好！拿了东西不要打架！！",
  "OROBAS.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-0.ancient": "又死掉？又回来？每次都疼吗？！为什么还要上去？！",
  "OROBAS.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-0.next": "回答",
  "OROBAS.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-1.char": "疼痛无关紧要。忍者仍在上面。",
  "OROBAS.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-1.next": "收下",
  "OROBAS.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-2.ancient": "当然有关！！拿上最亮的这个！至少不要再死了！！",
  "PAEL.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-0.ancient": "[thinky_dots]复仇者……你的心里太吵了。那团火，也从不睡觉么……？[/thinky_dots]",
  "PAEL.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-0.next": "回答",
  "PAEL.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-1.char": "茶道能令它沉寂片刻。使命未竟，便没有安眠。",
  "PAEL.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-1.next": "接受赠礼",
  "PAEL.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-2.ancient": "[thinky_dots]那就带走我的一部分吧……愿它替你承担一些重量……[/thinky_dots]",
  "PAEL.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.1-0r.ancient": "[thinky_dots]又是你……坐一会儿吧。愤怒也需要呼吸……[/thinky_dots]",
  "PAEL.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-0.ancient": "[thinky_dots]我看见一张温暖的餐桌……一个女人，一个孩子……然后火焰把他们带走……[/thinky_dots]",
  "PAEL.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-0.next": "回答",
  "PAEL.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-1.char": "冬子。枥木。",
  "PAEL.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-1.next": "接受赠礼",
  "PAEL.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-2.ancient": "[thinky_dots]每当你呼唤他们……另一团火就烧得更旺。这不是让人安眠的梦……[/thinky_dots]",
  "TANX.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-0.ancient": "[b]赤黑的战士！你的武器在哪里！？[/b]",
  "TANX.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-0.next": "回答",
  "TANX.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-1.char": "先回答。汝是忍者吗。",
  "TANX.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-1.next": "选择武器",
  "TANX.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-2.ancient": "[b]不是！我是嵌合兽之王！！现在拿上武器，与我一战！！[/b]",
  "TANX.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.1-0r.ancient": "[b]忍者杀手！让我看看你的空手道又变强了多少！！[/b]",
  "TANX.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-0.ancient": "[b]忍者杀手！与我一战！！[/b]",
  "TANX.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-0.next": "战斗",
  "TANX.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-1.char": "[i]坦克斯的巨拳与忍者杀手的空手道正面碰撞！KRAAASH！房间为之震动！[/i]",
  "TANX.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-1.next": "选择武器",
  "TANX.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-2.ancient": "[b]好空手道！！拿上一把武器，下次再战！！[/b]",
  "TEZCATARA.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-0.ancient": "哎呀，亲爱的。你身体里的火饿得直叫呢。让我喂喂它吧？",
  "TEZCATARA.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-0.next": "警告",
  "TEZCATARA.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-1.char": "那不是汝能饲养之物。",
  "TEZCATARA.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-1.next": "接受招待",
  "TEZCATARA.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-2.ancient": "不愿分享呀？真是个[jitter][b]小气[/b][/jitter]的孩子。那就先喂饱你吧。",
  "TEZCATARA.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.1-0r.ancient": "欢迎回来，小可爱。今天想烧掉软弱，还是烧掉敌人？",
  "TEZCATARA.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-0.ancient": "建筑师还活着呀？那你身体里的火，可要饿坏了。",
  "TEZCATARA.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-0.next": "回答",
  "TEZCATARA.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-1.char": "下一次交锋，我们之中必有一方不再回来。",
  "TEZCATARA.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-1.next": "接受招待",
  "TEZCATARA.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-2.ancient": "哎呀，真是个[jitter][b]可爱[/b][/jitter]的承诺。吃饱了再去吧！",
  "VAKUU.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-0.ancient": "你每夜都回到那张餐桌，然后再次看着妻儿死去。",
  "VAKUU.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-0.next": "质问",
  "VAKUU.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-1.char": "汝窥视了我的梦。汝是忍者吗。",
  "VAKUU.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-1.next": "查看契约",
  "VAKUU.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-2.ancient": "不是。我只是懂得怎样从伤口读出一个人。",
  "VAKUU.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.1-0r.ancient": "每当你梦见他们，奈落便从憎恨中取火。你称之为复仇，它称之为进食。",
  "VAKUU.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-0.ancient": "我不索取忍魂。替我杀死建筑师，我便让那些梦停止。",
  "VAKUU.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-0.next": "拒绝",
  "VAKUU.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-1.char": "冬子与枥木不是汝能开价的东西。",
  "VAKUU.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-1.next": "查看契约",
  "VAKUU.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-2.ancient": "我出售的是安眠。拒绝它的人，是你。",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-0r.char": "DOMO，建筑师=SAN。忍者杀手DESU。汝是忍者吗。",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-0r.next": "问候",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-1r.ancient": "不是。回到塔底去，否则我会抹除你。",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-1r.next": "战斗",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.0-2r.char": "拒绝。",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.1-0r.ancient": "你回来了？我明明已经杀了你。",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.1-0r.next": "回答",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.1-1r.char": "那说明你杀得不够彻底。",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.1-1r.next": "战斗",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.1-2r.ancient": "这次我会纠正错误。",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-0r.ancient": "你的动作变了。现在站在我面前的，究竟是谁？",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-0r.next": "拒绝",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-1r.char": "藤木户·健二。忍者杀手。",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-1r.next": "战斗",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.2-2r.ancient": "很好。那我就再杀死同一个人一次。",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.3-0r.ancient": "我还要杀你多少次？",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.3-0r.next": "备战",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.3-1r.char": "直到我们之中有一方不再归来。",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.3-1r.next": "战斗",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_CHARACTER.3-2r.ancient": "很好。那就让这一次成为终结。",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER.0-attack": "Both",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER.1-attack": "Both",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER.2-attack": "Both",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER.3-attack": "Both",
  "NEOW.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-0.ancient": "[sine]...两道...声音... 一具...身体.... 你是...何物...？[/sine]",
  "NEOW.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-0.next": "问候",
  "NEOW.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-1.char": "DOMO，涅奥=SAN。忍者杀手DESU。汝是忍者吗。",
  "NEOW.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-1.next": "继续",
  "NEOW.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-2.ancient": "[sine]...不是.... 向上.... 汝会...找到...应杀之人....[/sine]",
  "NEOW.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.1-0r.ancient": "[sine]...复仇者... 又一次.... 醒来... 向上去吧....[/sine]",
  "NEOW.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-0.ancient": "[sine]...你...抵达过.... 却又...回到...这里....[/sine]",
  "NEOW.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-0.next": "回答",
  "NEOW.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-1.char": "敌人未死。那便再上去。",
  "NEOW.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-1.next": "接受赐福",
  "NEOW.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-2.ancient": "[sine]...那么.... 再杀...一次....[/sine]",
  "DARV.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-0.char": "DOMO，达弗=SAN。忍者杀手DESU。",
  "DARV.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-0.next": "问候",
  "DARV.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-1.ancient": "名字怪吓人的，礼貌倒是真不错！赤黑色的家伙，我这堆里肯定有适合你的！",
  "DARV.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-1.next": "挑选",
  "DARV.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-2.char": "若能投掷，或能承受空手道，便足够。",
  "DARV.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.1-0r.ancient": "又把装备磨坏啦？拿一个拿一个——不过别朝我扔啊！",
  "DARV.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-0.ancient": "怪事！我的收藏里多了几枚用坏的手里剑。该不会是你以前落下的吧？",
  "DARV.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-0.next": "否认",
  "DARV.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-1.char": "不是。刃口的损伤，并非我的投法造成。",
  "DARV.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-1.next": "挑选",
  "DARV.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-2.ancient": "连这个都看得出来？好吧，那还是从新东西里挑一个！",
  "NONUPEIPE.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-0.ancient": "赤黑的刺客，你的杀意尚可，衣着却实在乏味。过来，让我替你添些光彩。",
  "NONUPEIPE.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-0.next": "回答",
  "NONUPEIPE.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-1.char": "装饰无用。不会妨碍空手道的赐福，可以收下。",
  "NONUPEIPE.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-1.next": "接受赐福",
  "NONUPEIPE.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-2.ancient": "真是不解风情。好吧——至少让你杀戮时显得体面些。",
  "NONUPEIPE.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.1-0r.ancient": "又是这身赤黑色？来吧，我顽固而能干的勇士。",
  "NONUPEIPE.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-0.ancient": "死去又归来这么多次，你居然一次也没有换过衣服。",
  "NONUPEIPE.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-0.next": "回答",
  "NONUPEIPE.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-1.char": "死亡改变不了使命。装束亦无须改变。",
  "NONUPEIPE.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-1.next": "接受赐福",
  "NONUPEIPE.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-2.ancient": "悲壮，却毫无品位。至少再收下一件我的赐福吧。",
  "OROBAS.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-0.ancient": "赤黑！杀气！身体里还有一个！？为什么两个？为什么都那么生气？！",
  "OROBAS.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-0.next": "回答",
  "OROBAS.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-1.char": "先回答。汝是忍者吗。",
  "OROBAS.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-1.next": "收下",
  "OROBAS.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-2.ancient": "不是！忍者很危险？你只杀忍者？很好！！拿个亮闪闪的冷静一下！",
  "OROBAS.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.1-0r.ancient": "又来？！没有少胳膊！很好！拿了东西不要打架！！",
  "OROBAS.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-0.ancient": "又死掉？又回来？每次都疼吗？！为什么还要上去？！",
  "OROBAS.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-0.next": "回答",
  "OROBAS.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-1.char": "疼痛无关紧要。忍者仍在上面。",
  "OROBAS.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-1.next": "收下",
  "OROBAS.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-2.ancient": "当然有关！！拿上最亮的这个！至少不要再死了！！",
  "PAEL.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-0.ancient": "[thinky_dots]复仇者……你的心里太吵了。那团火，也从不睡觉么……？[/thinky_dots]",
  "PAEL.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-0.next": "回答",
  "PAEL.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-1.char": "茶道能令它沉寂片刻。使命未竟，便没有安眠。",
  "PAEL.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-1.next": "接受赠礼",
  "PAEL.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-2.ancient": "[thinky_dots]那就带走我的一部分吧……愿它替你承担一些重量……[/thinky_dots]",
  "PAEL.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.1-0r.ancient": "[thinky_dots]又是你……坐一会儿吧。愤怒也需要呼吸……[/thinky_dots]",
  "PAEL.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-0.ancient": "[thinky_dots]我看见一张温暖的餐桌……一个女人，一个孩子……然后火焰把他们带走……[/thinky_dots]",
  "PAEL.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-0.next": "回答",
  "PAEL.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-1.char": "冬子。枥木。",
  "PAEL.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-1.next": "接受赠礼",
  "PAEL.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-2.ancient": "[thinky_dots]每当你呼唤他们……另一团火就烧得更旺。这不是让人安眠的梦……[/thinky_dots]",
  "TANX.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-0.ancient": "[b]赤黑的战士！你的武器在哪里！？[/b]",
  "TANX.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-0.next": "回答",
  "TANX.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-1.char": "先回答。汝是忍者吗。",
  "TANX.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-1.next": "选择武器",
  "TANX.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-2.ancient": "[b]不是！我是嵌合兽之王！！现在拿上武器，与我一战！！[/b]",
  "TANX.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.1-0r.ancient": "[b]忍者杀手！让我看看你的空手道又变强了多少！！[/b]",
  "TANX.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-0.ancient": "[b]忍者杀手！与我一战！！[/b]",
  "TANX.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-0.next": "战斗",
  "TANX.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-1.char": "[i]坦克斯的巨拳与忍者杀手的空手道正面碰撞！KRAAASH！房间为之震动！[/i]",
  "TANX.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-1.next": "选择武器",
  "TANX.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-2.ancient": "[b]好空手道！！拿上一把武器，下次再战！！[/b]",
  "TEZCATARA.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-0.ancient": "哎呀，亲爱的。你身体里的火饿得直叫呢。让我喂喂它吧？",
  "TEZCATARA.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-0.next": "警告",
  "TEZCATARA.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-1.char": "那不是汝能饲养之物。",
  "TEZCATARA.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-1.next": "接受招待",
  "TEZCATARA.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-2.ancient": "不愿分享呀？真是个[jitter][b]小气[/b][/jitter]的孩子。那就先喂饱你吧。",
  "TEZCATARA.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.1-0r.ancient": "欢迎回来，小可爱。今天想烧掉软弱，还是烧掉敌人？",
  "TEZCATARA.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-0.ancient": "建筑师还活着呀？那你身体里的火，可要饿坏了。",
  "TEZCATARA.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-0.next": "回答",
  "TEZCATARA.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-1.char": "下一次交锋，我们之中必有一方不再回来。",
  "TEZCATARA.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-1.next": "接受招待",
  "TEZCATARA.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-2.ancient": "哎呀，真是个[jitter][b]可爱[/b][/jitter]的承诺。吃饱了再去吧！",
  "VAKUU.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-0.ancient": "你每夜都回到那张餐桌，然后再次看着妻儿死去。",
  "VAKUU.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-0.next": "质问",
  "VAKUU.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-1.char": "汝窥视了我的梦。汝是忍者吗。",
  "VAKUU.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-1.next": "查看契约",
  "VAKUU.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-2.ancient": "不是。我只是懂得怎样从伤口读出一个人。",
  "VAKUU.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.1-0r.ancient": "每当你梦见他们，奈落便从憎恨中取火。你称之为复仇，它称之为进食。",
  "VAKUU.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-0.ancient": "我不索取忍魂。替我杀死建筑师，我便让那些梦停止。",
  "VAKUU.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-0.next": "拒绝",
  "VAKUU.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-1.char": "冬子与枥木不是汝能开价的东西。",
  "VAKUU.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-1.next": "查看契约",
  "VAKUU.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-2.ancient": "我出售的是安眠。拒绝它的人，是你。",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-0r.char": "DOMO，建筑师=SAN。忍者杀手DESU。汝是忍者吗。",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-0r.next": "问候",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-1r.ancient": "不是。回到塔底去，否则我会抹除你。",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-1r.next": "战斗",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.0-2r.char": "拒绝。",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.1-0r.ancient": "你回来了？我明明已经杀了你。",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.1-0r.next": "回答",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.1-1r.char": "那说明你杀得不够彻底。",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.1-1r.next": "战斗",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.1-2r.ancient": "这次我会纠正错误。",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-0r.ancient": "你的动作变了。现在站在我面前的，究竟是谁？",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-0r.next": "拒绝",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-1r.char": "藤木户·健二。忍者杀手。",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-1r.next": "战斗",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.2-2r.ancient": "很好。那我就再杀死同一个人一次。",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.3-0r.ancient": "我还要杀你多少次？",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.3-0r.next": "备战",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.3-1r.char": "直到我们之中有一方不再归来。",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.3-1r.next": "战斗",
  "THE_ARCHITECT.talk.NINJA_SLAYER_CHARACTER_NINJA_SLAYER_DEBUG_CHARACTER.3-2r.ancient": "很好。那就让这一次成为终结。",
  "THE_ARCHITECT.talk.NINJA_SLAYER_DEBUG_CHARACTER.0-attack": "Both",
  "THE_ARCHITECT.talk.NINJA_SLAYER_DEBUG_CHARACTER.1-attack": "Both",
  "THE_ARCHITECT.talk.NINJA_SLAYER_DEBUG_CHARACTER.2-attack": "Both",
  "THE_ARCHITECT.talk.NINJA_SLAYER_DEBUG_CHARACTER.3-attack": "Both"
}
